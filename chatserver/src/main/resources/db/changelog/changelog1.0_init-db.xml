<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:pro="http://www.liquibase.org/xml/ns/pro"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
  http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd
  http://www.liquibase.org/xml/ns/pro
  http://www.liquibase.org/xml/ns/pro/liquibase-pro-3.8.xsd">

    <changeSet id="create-chat-user-table" author="Caleb">
        <createTable tableName="chat_user">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="username" type="VARCHAR(255)">
                <constraints unique="true"/>
            </column>

            <column name="firstname" type="VARCHAR(255)"/>
            <column name="lastname" type="VARCHAR(255)"/>

            <column name="email" type="VARCHAR(255)">
                <constraints unique="true"/>
            </column>

            <column name="profile_picture_url" type="VARCHAR(512)"/>

            <column name="mail_box_id" type="VARCHAR(36)">
                <constraints unique="true"/>
            </column>

            <!-- ✅ AUTO CREATED -->
            <column name="created_at" type="TIMESTAMP"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <!-- ✅ AUTO UPDATED -->
            <column name="updated_at" type="TIMESTAMP"
                    defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <!-- ✅ Ensure updated_at auto-updates (MySQL-specific) -->
        <modifyDataType tableName="chat_user"
                        columnName="updated_at"
                        newDataType="TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
    </changeSet>

</databaseChangeLog>